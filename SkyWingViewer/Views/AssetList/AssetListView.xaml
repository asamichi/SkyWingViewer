<UserControl x:Class="SkyWingViewer.Views.AssetListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SkyWingViewer.Views"
             mc:Ignorable="d" 
             xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
             xmlns:vm="clr-namespace:SkyWingViewer.ViewModels"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <!--WhenAddType: 対応形式が増えたらここに追加。対応する VM も追加-->
        <DataTemplate DataType="{x:Type vm:ImageAssetViewModel}">
            <!--<Image Source="{Binding AssetPath, IsAsync=True}"/>-->
            <local:ImageAssetView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OtherAssetViewModel}">
            <local:OtherAssetView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DirectoryViewModel}">
            <local:DirectoryView/>
        </DataTemplate>
    </UserControl.Resources>

    <!--暫定で、とりあえず2ページ分くらい先読みしておく(CacheXXX の設定)-->
    <ListView
        x:Name="AssetsList"
        ItemsSource="{Binding Assets, Mode=OneWay, NotifyOnTargetUpdated=True}"
        TargetUpdated="AssetsListTargetUpdated"
        ScrollViewer.CanContentScroll="True"
        VirtualizingPanel.CacheLength="100"
        VirtualizingPanel.CacheLengthUnit="Item">
        <!--CacheLengthUnit=Page はうまく動かない。ユーザーコントロール出してるから？安定して先読みできる Item に一旦変更。先読み数は WQHD でも画面内50枚程度なので、一旦その程度で-->
        <!--VirtualizingPanel.VirtualizationMode="Recycling">-->
        <!--Recyclingは実装と相性が悪いのかわからないが、スクロースしてもスクロール先のサムネイル作成処理が走らない。一旦保留。OnIsVisibleChangedが発火して無いことを確認済み -->
        <!--TODO: DataContextChanged で読み込み発火するようにすると解決する。どちらがいいかは後程検討-->
        
        <!--ItemsSource="{Binding Assets, Mode=OneWay, NotifyOnTargetUpdated=True}"
        TargetUpdated="AssetsListTargetUpdated" でAssets が変わったタイミングでイベント発火させられる。
        最上までスクロールさせようと思ったが、IsVisibleChanged が発火しないので中断。-->

        <ListView.ItemContainerStyle>
            <Style TargetType="ListViewItem">
                <Setter Property="Width" Value="210"/>
                <Setter Property="Height" Value="320"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <!--ダブルクリック時の動作-->
                <EventSetter Event="MouseDoubleClick" Handler="ListViewItemMouseDoubleClick"/>
                <!--右クリックの操作-->
                <Setter Property="ContextMenu" Value="{StaticResource AssetContextMenu}"/>
            </Style>
        </ListView.ItemContainerStyle>
        <i:Interaction.Triggers>
            <i:EventTrigger EventName="SelectionChanged">
                <i:InvokeCommandAction 
            Command="{Binding UpdateSelectionCommand}" 
            CommandParameter="{Binding SelectedItems, ElementName=AssetsList}" />
            </i:EventTrigger>
        </i:Interaction.Triggers>
        <ListView.ItemsPanel>
            <ItemsPanelTemplate>
                <vwp:VirtualizingWrapPanel/>
            </ItemsPanelTemplate>
        </ListView.ItemsPanel>
        <ListView.ItemTemplate>
            <DataTemplate>
                <ContentControl Content="{Binding}"/>
            </DataTemplate>
        </ListView.ItemTemplate>
    </ListView>
</UserControl>
