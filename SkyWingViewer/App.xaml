<Application x:Class="SkyWingViewer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SkyWingViewer"
             xmlns:vm="clr-namespace:SkyWingViewer.ViewModels"
             xmlns:views="clr-namespace:SkyWingViewer.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Application.Resources>
        <!--AI 作ここから-->
        <!--MahApps:  MahApps によるテーマ適用処理-->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />

                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Dark.Steel.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="ListView" BasedOn="{StaticResource MahApps.Styles.ListView}">
                <!--<Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
                <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True"/>-->
                <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.ThemeBackground}"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <Style TargetType="ListViewItem" BasedOn="{StaticResource MahApps.Styles.ListViewItem}">
                <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Text}"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style TargetType="TextBox" BasedOn="{StaticResource MahApps.Styles.TextBox}">
                <Setter Property="Margin" Value="2"/>
            </Style>
            <Style TargetType="UserControl">
                <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.ThemeBackground}"/>
            </Style>
            <!--AI 作ここまで-->


            <DataTemplate DataType="{x:Type vm:AssetListViewModel}">
                <views:AssetListView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:TargetPathBarViewModel}">
                <views:TargetPathBarView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:AssetListItemFooterViewModel}">
                <views:AssetListItemFooterView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:FavoriteListViewModel}">
                <views:FavoriteListView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:AssetInformationViewModel}">
                <views:AssetInformationView/>
            </DataTemplate>

            <!--右クリックメニュー用-->
            <!--参考：https://gist.github.com/pinzolo/3103668-->
            <!--x:Keyで他のviewから呼び出せるようにする-->
            <ContextMenu x:Key="AssetContextMenu">
                <ContextMenu.ItemsSource>
                    <!--バインディング-->
                    <Binding Path="ContextMenuItems"/>
                </ContextMenu.ItemsSource>
                <ContextMenu.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <!--Header はメニュー名のこと。それぞれ対応するパラメータをバインド-->
                        <Setter Property="Header"   Value="{Binding Name}"/>
                        <Setter Property="Command"  Value="{Binding Command}"/>
                        <!--後半部分でバインディング対象を親を辿っていって最初に見つかる ContextMenu 型に指定して、
                        そのうえでそこから PlacementTarget(どこで（どのコントロールで、ViewList ならリストの中のどこのアイテムで）開かれたのか)を取得し、
                        そのデータコンテキストを指定-->
                        <Setter Property="CommandParameter" Value="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <!-- セパレーター切り替え。 IsSeparator で分岐させる。 -->
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="MenuItem">
                                            <Separator/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContextMenu.ItemContainerStyle>
            </ContextMenu>
        </ResourceDictionary>
    </Application.Resources>

    
</Application>
